{
    "name": "ekunitsa-resume",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint:scss": "stylelint \"./src/**/*.scss\"",
        "lint:biome": "biome check .",
        "lint": "concurrently \"npm run lint:biome\" \"npm run lint:scss\"",
        "pre-commit": "npm run lint",
        "prepare": "husky"
    },
    "dependencies": {
        "@next-auth/prisma-adapter": "^1.0.7",
        "@prisma/client": "^6.19.3",
        "@tanstack/react-table": "^8.21.3",
        "bcrypt": "^6.0.0",
        "classnames": "^2.5.1",
        "dayjs": "^1.11.21",
        "next": "^16.2.10",
        "next-auth": "^4.24.14",
        "next-intl": "^4.13.1",
        "prisma": "^6.19.3",
        "react": "^19",
        "react-dom": "^19",
        "react-hook-form": "^7.81.0",
        "react-icons": "^5.7.0",
        "scss-reset": "^1.4.6",
        "sharp": "^0.35.3"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.2",
        "@svgr/webpack": "^8.1.0",
        "@types/bcrypt": "^6.0.0",
        "@types/node": "^26.1.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "concurrently": "^10.0.3",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.8",
        "sass": "^1.101.0",
        "stylelint": "^17.14.0",
        "stylelint-config-standard": "^40.0.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.2.0",
        "typescript": "^6"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx}": [
            "biome check --no-errors-on-unmatched"
        ],
        "*.{css,scss}": [
            "stylelint --allow-empty-input"
        ]
    }
}
